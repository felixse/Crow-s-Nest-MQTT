<UserControl
    x:Class="CrowsNestMqtt.UI.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="using:AvaloniaEdit"
    xmlns:aeControls="using:AvaloniaEdit.TextMate"
    xmlns:controls="using:FluentAvalonia.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
    xmlns:vm="using:CrowsNestMqtt.UI.ViewModels"
    xmlns:vw="using:CrowsNestMqtt.UI.Views"
    d:DesignHeight="600"
    d:DesignWidth="800"
    x:CompileBindings="False"
    x:DataType="vm:MainViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <!--  This DataContext is used only for design-time IntelliSense.  -->
        <!--  It is overridden at runtime by the ViewModel assigned in code-behind  -->
        <vm:MainViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <!--  GridSplitters: 4px pill, transparent at rest, clearly highlighted on hover/drag  -->
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="GridSplitter:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>
        <Style Selector="GridSplitter:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>
        <!--  DataGrid headers blend into the surrounding card background  -->
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Styles>

    <!--  Main layout Grid (without settings)  -->
    <Grid ColumnDefinitions="*" RowDefinitions="Auto,Auto,*,Auto">

        <!--  Title Bar  -->
        <Grid
            x:Name="TitleBarGrid"
            Grid.Row="0"
            Height="48"
            Background="Transparent"
            ColumnDefinitions="Auto,Auto,*">
            <!--  App Icon  -->
            <Image
                Grid.Column="0"
                Width="16"
                Height="16"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Source="avares://CrowsNestMqtt.App/Assets/icon.ico" />
            <!--  App Title  -->
            <TextBlock
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                FontSize="12"
                Text="Crow's Nest MQTT" />
            <!--  Search / Command Box  -->
            <AutoCompleteBox
                x:Name="CommandAutoCompleteBox"
                Grid.Column="2"
                Width="600"
                Margin="16,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FilterMode="StartsWith"
                ItemsSource="{Binding CommandSuggestions}"
                MinimumPrefixLength="1"
                PlaceholderText="Enter command or search query..."
                Text="{Binding CommandText, Mode=TwoWay}">
                <AutoCompleteBox.KeyBindings>
                    <KeyBinding Command="{Binding SubmitInputCommand}" Gesture="Enter" />
                </AutoCompleteBox.KeyBindings>
            </AutoCompleteBox>
        </Grid>


        <!--  Toolbar  -->
        <Border
            Grid.Row="1"
            Margin="8,4,8,0"
            Classes="Card">
            <controls:FACommandBar DefaultLabelPosition="Right">
                <controls:FACommandBar.PrimaryCommands>
                    <controls:FACommandBarButton
                        Command="{Binding ConnectCommand}"
                        Label="Connect..."
                        ToolTip.Tip="Connect">
                        <controls:FACommandBarButton.IconSource>
                            <controls:FAPathIconSource Data="{StaticResource plug_connected_regular}" />
                        </controls:FACommandBarButton.IconSource>
                    </controls:FACommandBarButton>
                    <controls:FACommandBarButton
                        Classes.Connecting="{Binding IsConnecting}"
                        Command="{Binding DisconnectCommand}"
                        ToolTip.Tip="Disconnect">
                        <controls:FACommandBarButton.Styles>
                            <Style Selector="controls|FACommandBarButton">
                                <Setter Property="Label" Value="Disconnect" />
                            </Style>
                            <Style Selector="controls|FACommandBarButton.Connecting">
                                <Setter Property="Label" Value="Cancel" />
                            </Style>
                        </controls:FACommandBarButton.Styles>
                        <controls:FACommandBarButton.IconSource>
                            <controls:FAPathIconSource Data="{StaticResource plug_disconnected_regular}" />
                        </controls:FACommandBarButton.IconSource>
                    </controls:FACommandBarButton>
                    <controls:FACommandBarSeparator />
                    <controls:FACommandBarButton
                        Command="{Binding ClearHistoryCommand}"
                        Label="Clear"
                        ToolTip.Tip="Clear">
                        <controls:FACommandBarButton.IconSource>
                            <controls:FAFontIconSource FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                        </controls:FACommandBarButton.IconSource>
                    </controls:FACommandBarButton>
                    <controls:FACommandBarButton
                        x:Name="PauseResumeButton"
                        Command="{Binding PauseResumeCommand}"
                        Label="Pause/Resume"
                        ToolTip.Tip="Pause/Resume">
                        <controls:FACommandBarButton.IconSource>
                            <controls:FAFontIconSource FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE769;" />
                        </controls:FACommandBarButton.IconSource>
                    </controls:FACommandBarButton>
                    <controls:FACommandBarSeparator />
                    <controls:FACommandBarButton
                        x:Name="DeleteTopicButton"
                        Command="{Binding DeleteTopicCommand}"
                        IsEnabled="{Binding IsDeleteButtonEnabled}"
                        Label="Delete Topic"
                        ToolTip.Tip="Delete selected topic's retained messages">
                        <controls:FACommandBarButton.IconSource>
                            <controls:FAPathIconSource Data="{StaticResource delete_regular}" />
                        </controls:FACommandBarButton.IconSource>
                    </controls:FACommandBarButton>
                    <controls:FACommandBarSeparator />
                    <controls:FACommandBarButton
                        x:Name="ExportAllButton"
                        Command="{Binding ExportAllCommand}"
                        IsEnabled="{Binding IsExportAllButtonEnabled}"
                        Label="Export All"
                        ToolTip.Tip="Export all messages from selected topic (max 100)">
                        <controls:FACommandBarButton.IconSource>
                            <controls:FAPathIconSource Data="{StaticResource export_regular}" />
                        </controls:FACommandBarButton.IconSource>
                    </controls:FACommandBarButton>
                    <controls:FACommandBarButton
                        x:Name="PublishButton"
                        Command="{Binding TogglePublishWindowCommand}"
                        Label="Publish"
                        ToolTip.Tip="Open publish window (Ctrl+Shift+M)">
                        <controls:FACommandBarButton.IconSource>
                            <controls:FAPathIconSource Data="{StaticResource send_regular}" />
                        </controls:FACommandBarButton.IconSource>
                    </controls:FACommandBarButton>
                    <controls:FACommandBarSeparator />
                    <controls:FACommandBarButton Command="{Binding OpenSettingsCommand}" Label="Settings">
                        <controls:FACommandBarButton.IconSource>
                            <controls:FAPathIconSource Data="{StaticResource settings_regular}" />
                        </controls:FACommandBarButton.IconSource>
                    </controls:FACommandBarButton>
                </controls:FACommandBar.PrimaryCommands>
            </controls:FACommandBar>
        </Border>

        <!--  Main Content Area using DockPanel  -->
        <Grid
            Grid.Row="2"
            ColumnDefinitions="*,Auto"
            RowDefinitions="*">

            <!--  Main Content Grid (Fills Remaining Space)  -->
            <Grid
                Grid.Row="0"
                Grid.Column="0"
                ColumnDefinitions="1*,Auto,3*">
                <!--  Left Panel: Topic List (Card)  -->
                <Border
                    Grid.Column="0"
                    MinWidth="200"
                    Margin="8,8,0,8"
                    Classes="Card">
                    <Grid RowDefinitions="Auto,*">
                        <Border
                            Grid.Row="0"
                            Padding="8"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                LineHeight="20"
                                Text="Topics" />
                        </Border>
                        <TreeView
                            x:Name="TopicTreeView"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            Focusable="True"
                            ItemsSource="{Binding TopicTreeNodes}"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="{x:Type vm:NodeViewModel}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Text="{Binding Name}"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding MessageCount}" />
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.Styles>
                                <!--  Style the internal ScrollViewer in TreeView  -->
                                <Style Selector="TreeView > ScrollViewer">
                                    <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
                                    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                                </Style>
                                <Style x:DataType="vm:NodeViewModel" Selector="TreeViewItem">
                                    <Setter Property="IsVisible" Value="{Binding IsVisible}" />
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.Styles>
                        </TreeView>
                    </Grid>
                </Border>

                <!--  Vertical Grid Splitter: 4px pill centred in an 8px gap (2px clear on each side)  -->
                <GridSplitter
                    Grid.Column="1"
                    Width="4"
                    Margin="2,8,2,8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Cursor="SizeWestEast"
                    Focusable="True"
                    IsTabStop="True"
                    ResizeDirection="Columns" />

                <!--  Right Panel: Details and History  -->
                <!--  Moved this Grid to Column 2  -->
                <!--  Right Panel: Details, JSON Viewer, and History  -->
                <!--  Changed RowDefinitions: Details(Auto), Splitter(Auto), JsonViewer(*), Splitter(Auto), History(*)  -->
                <Grid Grid.Column="2" RowDefinitions="*,Auto,*,Auto,*">
                    <!--  Row layout: Details (*), Splitter, Payload (*), Splitter, History (*)  -->

                    <!--  Row 0: Message Details (Metadata & User Properties)  -->
                    <Grid
                        Grid.Row="0"
                        Margin="0,8,8,0"
                        ColumnDefinitions="*,Auto,*">
                        <!--  Column 0: Metadata  -->
                        <Border Grid.Column="0" Classes="Card">
                            <Grid Grid.Row="0" RowDefinitions="Auto,*">
                                <Border
                                    Padding="8"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        LineHeight="20"
                                        Text="Message Metadata" />
                                </Border>
                                <DataGrid
                                    Grid.Row="1"
                                    AutoGenerateColumns="False"
                                    BorderThickness="0"
                                    CanUserResizeColumns="True"
                                    GridLinesVisibility="None"
                                    IsReadOnly="True"
                                    ItemsSource="{Binding MessageMetadata}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="Auto"
                                            Binding="{Binding Key}"
                                            Header="Key" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Value}"
                                            Header="Value" />
                                        <DataGridTemplateColumn Width="Auto" Header="">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate DataType="{x:Type vm:MetadataItem}">
                                                    <Button
                                                        Padding="4"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Classes.ResponseReceived="{Binding IconViewModel.IsResponseReceived, FallbackValue=False}"
                                                        Command="{Binding $parent[DataGrid].DataContext.NavigateToResponseCommand}"
                                                        CommandParameter="{Binding IconViewModel.RequestMessageId, FallbackValue={x:Null}}"
                                                        Cursor="Hand"
                                                        IsEnabled="{Binding IconViewModel.IsClickable, FallbackValue=False}"
                                                        IsVisible="{Binding HasIcon}"
                                                        ToolTip.Tip="{Binding IconViewModel.ToolTip, FallbackValue={x:Null}}">
                                                        <PathIcon Width="16" Height="16">
                                                            <PathIcon.Styles>
                                                                <!--  Default: clock icon for pending  -->
                                                                <Style Selector="PathIcon">
                                                                    <Setter Property="Data" Value="{StaticResource clock_icon}" />
                                                                    <Setter Property="Foreground" Value="#666666" />
                                                                </Style>
                                                                <!--  Arrow icon when response received  -->
                                                                <Style Selector="Button.ResponseReceived PathIcon">
                                                                    <Setter Property="Data" Value="{StaticResource arrow_icon}" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccess}" />
                                                                </Style>
                                                                <Style Selector="Button:pointerover PathIcon">
                                                                    <Setter Property="Foreground" Value="#333333" />
                                                                </Style>
                                                                <Style Selector="Button:disabled PathIcon">
                                                                    <Setter Property="Foreground" Value="#CCCCCC" />
                                                                </Style>
                                                            </PathIcon.Styles>
                                                        </PathIcon>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!--  Warning icon column for expired messages  -->
                                        <DataGridTemplateColumn Width="Auto" Header="">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate DataType="{x:Type vm:MetadataItem}">
                                                    <Panel IsVisible="{Binding HasWarningIcon}">
                                                        <PathIcon
                                                            Width="16"
                                                            Height="16"
                                                            Data="{StaticResource warning_icon}"
                                                            Foreground="{DynamicResource SystemFillColorCaution}"
                                                            ToolTip.Tip="{Binding WarningIconViewModel.ToolTip, FallbackValue={x:Null}}" />
                                                    </Panel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!--  Column 1: Vertical Grid Splitter: 4px pill centred in an 8px gap  -->
                        <GridSplitter
                            Grid.Column="1"
                            Width="4"
                            Margin="2,0,2,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"
                            AutomationProperties.Name="Details Splitter"
                            Cursor="SizeWestEast"
                            Focusable="True"
                            IsTabStop="True"
                            ResizeDirection="Columns" />

                        <!--  Column 2: User Properties  -->
                        <Border Grid.Column="2" Classes="Card">
                            <Grid RowDefinitions="Auto,*">
                                <Border
                                    Grid.Row="0"
                                    Padding="8"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        LineHeight="20"
                                        Text="User Properties" />
                                </Border>
                                <DataGrid
                                    Grid.Row="1"
                                    AutoGenerateColumns="False"
                                    BorderThickness="0"
                                    CanUserResizeColumns="True"
                                    GridLinesVisibility="None"
                                    IsReadOnly="True"
                                    ItemsSource="{Binding MessageUserProperties}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="Auto"
                                            Binding="{Binding Key}"
                                            Header="Key" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Value}"
                                            Header="Value" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!--  Row 1: Horizontal Grid Splitter: 4px pill centred in an 8px gap (2px clear on each side)  -->
                    <GridSplitter
                        Grid.Row="1"
                        Height="4"
                        Margin="0,2,8,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Section Splitter 1"
                        Cursor="SizeNorthSouth"
                        Focusable="True"
                        IsTabStop="True"
                        ResizeDirection="Rows" />

                    <!--  Row 2: Payload Card  -->
                    <Border
                        Grid.Row="2"
                        Margin="0,0,8,0"
                        Classes="Card">
                        <Grid RowDefinitions="Auto,*">
                            <Border
                                Grid.Row="0"
                                Padding="8"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    LineHeight="20"
                                    Text="Payload" />
                            </Border>
                            <vw:PayloadViewer Grid.Row="1" MinHeight="80" />
                        </Grid>
                    </Border>

                    <!--  Row 3: Horizontal Grid Splitter: 4px pill centred in an 8px gap  -->
                    <GridSplitter
                        Grid.Row="3"
                        Height="4"
                        Margin="0,2,8,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Section Splitter 2"
                        Cursor="SizeNorthSouth"
                        Focusable="True"
                        IsTabStop="True"
                        ResizeDirection="Rows" />

                    <!--  Row 4: Message History  -->
                    <Border
                        Grid.Row="4"
                        Margin="0,0,8,8"
                        Classes="Card">
                        <Grid RowDefinitions="Auto,*">
                            <Border
                                Grid.Row="0"
                                Padding="8"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    LineHeight="20"
                                    Text="Messages" />
                            </Border>
                            <ListBox
                                x:Name="MessageHistoryListBox"
                                Grid.Row="1"
                                ItemsSource="{Binding FilteredMessageHistory}"
                                SelectedItem="{Binding SelectedMessage, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MessageViewModel">
                                        <!--  Use DockPanel for layout: Time Left, Buttons Right, Payload Center  -->
                                        <DockPanel MinWidth="300" LastChildFill="True">
                                            <!--  Copy Button (Right Aligned)  -->
                                            <Button
                                                Margin="4,0,0,0"
                                                Padding="4"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ListBox].DataContext.CopyPayloadCommand}"
                                                CommandParameter="{Binding}"
                                                DockPanel.Dock="Right"
                                                ToolTip.Tip="Copy Payload">
                                                <PathIcon
                                                    Width="12"
                                                    Height="12"
                                                    Data="{StaticResource copy_regular}" />
                                            </Button>

                                            <!--  T022: Export Button (Right Aligned, left of Copy Button)  -->
                                            <Button
                                                Margin="4,0,0,0"
                                                Padding="4"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ListBox].DataContext.ExportMessageCommand}"
                                                CommandParameter="{Binding}"
                                                DockPanel.Dock="Right"
                                                ToolTip.Tip="Export this message">
                                                <PathIcon
                                                    Width="12"
                                                    Height="12"
                                                    Data="{StaticResource export_regular}" />
                                            </Button>

                                            <!--  DisplayText (Fills remaining space)  -->
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Classes.Expired="{Binding IsExpired}"
                                                Text="{Binding DisplayText}"
                                                TextTrimming="CharacterEllipsis">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock.Expired">
                                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                                        <Setter Property="Foreground" Value="Gray" />
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <!--  End of Main Content Grid  -->

        </Grid>
        <!--  End of Main Content Area DockPanel  -->

        <!--  Status Bar  -->
        <Border
            Grid.Row="3"
            Height="32"
            Padding="8,0"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel
                Orientation="Horizontal"
                Spacing="8"
                TextElement.FontSize="12">
                <TextBlock VerticalAlignment="Center" Text="Status:" />
                <PathIcon
                    Width="12"
                    Height="12"
                    VerticalAlignment="Center"
                    Classes.IsConnected="{Binding IsConnected}"
                    Classes.IsConnecting="{Binding IsConnecting}"
                    Classes.IsDisconnected="{Binding IsDisconnected}"
                    ToolTip.Tip="{Binding ConnectionStatus}">
                    <PathIcon.Styles>
                        <Style Selector="PathIcon.IsDisconnected">
                            <Setter Property="Data" Value="{StaticResource plug_disconnected_regular}" />
                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCritical}" />
                        </Style>
                        <Style Selector="PathIcon.IsConnecting">
                            <Setter Property="Data" Value="{StaticResource plug_disconnected_regular}" />
                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCaution}" />
                        </Style>
                        <Style Selector="PathIcon.IsConnected">
                            <Setter Property="Data" Value="{StaticResource plug_connected_regular}" />
                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccess}" />
                        </Style>
                    </PathIcon.Styles>
                </PathIcon>
                <TextBlock VerticalAlignment="Center" Text="{Binding IsPaused, StringFormat='Paused: {0}'}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontStyle="Italic"
                    Foreground="{DynamicResource SystemFillColorCaution}"
                    IsVisible="{Binding IsTopicFilterActive}"
                    Text="(Filtered)" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontStyle="Italic"
                    Foreground="Gray"
                    Text="{Binding StatusBarText}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontStyle="Italic"
                    Foreground="DodgerBlue"
                    IsVisible="{Binding SearchStatusViewModel.IsVisible}"
                    Text="{Binding SearchStatusViewModel.StatusText}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontStyle="Italic"
                    Foreground="{DynamicResource SystemFillColorCritical}"
                    IsVisible="{Binding IsConnecting}"
                    Text="{Binding ConnectionStatusMessage}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SystemFillColorCritical}"
                    IsVisible="{Binding HasConnectionError}"
                    Text="{Binding ConnectionStatusMessage}" />
            </StackPanel>
        </Border>

        <!--  Settings Modal Overlay  -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="99"
            Grid.Column="0"
            Grid.ColumnSpan="99"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#80000000"
            IsVisible="{Binding IsSettingsVisible}"
            ZIndex="1000">
            <Border
                MaxWidth="768"
                MaxHeight="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                BorderThickness="1"
                BoxShadow="0 8 32 0 #40000000"
                ClipToBounds="True"
                CornerRadius="8">
                <Grid RowDefinitions="Auto,*">
                    <!--  Title bar  -->
                    <Border Grid.Row="0">
                        <DockPanel>
                            <TextBlock
                                Padding="16,8"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="Settings" />
                            <Button
                                Width="46"
                                Height="32"
                                Margin="0,-2,0,0"
                                Padding="8,4"
                                HorizontalAlignment="Right"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                ClipToBounds="True"
                                Command="{Binding OpenSettingsCommand}"
                                CornerRadius="0 8 0 0"
                                DockPanel.Dock="Right">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="#E81123" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Style>
                                    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="#F1707A" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Style>
                                </Button.Styles>
                                <controls:FAFontIcon
                                    FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                    Foreground="{Binding $parent[Button].Foreground}"
                                    Glyph="&#xE8BB;" />
                            </Button>
                        </DockPanel>
                    </Border>
                    <ScrollViewer
                        Grid.Row="1"
                        MaxHeight="500"
                        Padding="24">
                        <vw:SettingsPanel />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>

    </Grid>
    <!--  End of Main Layout Grid  -->
</UserControl>
